<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context="com.zoffcc.applications.trifa.ConferenceMessageListActivity">

    <androidx.appcompat.widget.Toolbar xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/conf_search_view_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            app:iconifiedByDefault="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.appcompat.widget.Toolbar>

    <!-- the layout which will contain (host) the drawerLayout -->
    <FrameLayout
        android:id="@+id/drawer_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ml_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentTop="true"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="6dip"
                    android:layout_marginRight="1dip"
                    android:padding="2dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/circle_red" />

                <ImageView
                    android:id="@+id/ml_status_icon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_alignParentTop="true"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="1dip"
                    android:layout_marginRight="6dip"
                    android:padding="2dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/circle_green" />


                <TextView
                    android:id="@+id/ml_maintext"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical"
                    android:padding="8dp"
                    android:text="@string/layout___name"
                    android:textColor="@color/md_black_1000"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:text=""
                    android:visibility="gone"></TextView>

                <ImageButton
                    android:id="@+id/ml_phone_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical"
                    android:layout_margin="7dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:onClick="start_call_to_friend"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/circle_orange" />


            </LinearLayout>


            <fragment
                android:id="@+id/ml_fragment"
                android:name="com.zoffcc.applications.trifa.ConferenceMessageListFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:layout="@layout/conference_message_list_layout" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="15dp"
                android:layout_gravity="bottom"
                android:layout_weight="0"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/ml_friend_typing"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:cursorVisible="true"
                    android:singleLine="true"
                    android:text=""
                    android:textColor="@android:color/primary_text_light"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/emoji_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="@dimen/chat_input_bar_margin_h"
                android:layout_marginEnd="@dimen/chat_input_bar_margin_h"
                android:layout_marginBottom="@dimen/chat_input_bar_margin_bottom"
                android:layout_weight="0"
                android:background="@drawable/bg_chat_input_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/chat_input_bar_padding_h"
                android:paddingTop="@dimen/chat_input_bar_padding_v"
                android:paddingEnd="@dimen/chat_input_bar_padding_h"
                android:paddingBottom="@dimen/chat_input_bar_padding_v">

                <ImageButton
                    android:id="@+id/insert_emoji"
                    android:layout_width="@dimen/chat_input_icon_size"
                    android:layout_height="@dimen/chat_input_icon_size"
                    android:layout_gravity="center_vertical"
                    android:layout_margin="@dimen/chat_input_icon_margin"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/chat_input_icon_padding"
                    android:scaleType="fitCenter"
                    app:srcCompat="@drawable/i_emoji_google_category_people"
                    tools:ignore="ContentDescription" />

                <com.vanniktech.emoji.EmojiEditText
                    android:id="@+id/ml_new_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chat_message_field"
                    android:cursorVisible="true"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:imeOptions="flagNoPersonalizedLearning|actionSend"
                    android:includeFontPadding="false"
                    android:inputType="textMultiLine"
                    android:maxLines="5"
                    android:paddingStart="@dimen/chat_input_field_padding_h"
                    android:paddingTop="@dimen/chat_input_field_padding_v"
                    android:paddingEnd="@dimen/chat_input_field_padding_h"
                    android:paddingBottom="@dimen/chat_input_field_padding_v"
                    android:singleLine="false"
                    android:text=""
                    android:textColor="@color/md_black_1000"
                    android:textSize="@dimen/chat_input_text_size" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/ml_button_01"
                        android:layout_width="@dimen/chat_input_icon_size"
                        android:layout_height="@dimen/chat_input_icon_size"
                        android:layout_gravity="center_vertical"
                        android:layout_margin="@dimen/chat_input_icon_margin"
                        android:layout_weight="0"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:onClick="send_message_onclick"
                        android:padding="@dimen/chat_input_icon_padding"
                        android:scaleType="fitCenter"
                        android:src="@android:drawable/ic_menu_send" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <include layout="@layout/floating_action_button_conference" />

    </FrameLayout>

</LinearLayout>


